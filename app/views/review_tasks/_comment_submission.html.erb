<%# Partial for rendering the submit button and selection counter toolbar %>
<%# Locals: review_task - a ReviewTask instance, comments - collection of ReviewComment instances %>

<!-- Checklist Toolbar - Responsive -->
<div id="comment-submission-toolbar" class="linear-checklist-toolbar relative z-10 flex-col sm:flex-row gap-3 sm:gap-2">
  <div class="linear-checklist-toolbar-left w-full sm:w-auto">
    <button type="button"
            class="linear-btn linear-btn-ghost text-[12px]"
            data-comment-checklist-target="selectAllButton"
            data-action="click->comment-checklist#toggleAll">
      Select All
    </button>
    <span class="linear-checklist-counter text-[11px] md:text-[12px]"
          data-comment-checklist-target="counter">
      0 of <%= comments.count { |c| c.pending? } %> selected
    </span>
  </div>
  <div class="linear-checklist-toolbar-right w-full sm:w-auto">
    <%= form_with url: submit_review_task_review_comments_path(review_task),
                  method: :post,
                  data: { turbo_stream: true, comment_checklist_target: "form" },
                  class: "flex flex-col sm:flex-row items-stretch sm:items-center gap-2 w-full sm:w-auto" do |f| %>
      <!-- Custom Event Selector with Icons -->
      <div class="relative w-full sm:w-auto" data-controller="event-selector">
        <input type="hidden" name="event" value="COMMENT" data-event-selector-target="hiddenInput">
        <button type="button"
                class="linear-input flex items-center gap-2 pr-8 cursor-pointer w-full sm:w-auto justify-between"
                data-event-selector-target="button"
                data-action="click->event-selector#toggle">
          <span data-event-selector-target="selectedIcon" class="flex items-center text-[color:var(--color-text-secondary)]">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
          </span>
          <span data-event-selector-target="selectedLabel" class="text-[13px]">Comment only</span>
          <svg class="w-4 h-4 absolute right-2 sm:right-2 text-[color:var(--color-text-tertiary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="hidden absolute top-full mt-1 right-0 left-0 sm:left-auto w-full sm:w-48 bg-[color:var(--color-bg-secondary)] border border-[color:var(--color-border-default)] rounded-md shadow-lg z-50"
             data-event-selector-target="dropdown">
          <ul class="py-1">
            <li>
              <button type="button"
                      class="w-full px-3 py-3 sm:py-2 text-left text-[13px] flex items-center gap-2 hover:bg-[color:var(--color-bg-tertiary)] bg-[color:var(--color-bg-tertiary)]"
                      data-action="click->event-selector#select"
                      data-value="COMMENT"
                      data-label="Comment only">
                <span class="event-icon text-[color:var(--color-text-secondary)]">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                  </svg>
                </span>
                Comment only
              </button>
            </li>
            <li>
              <button type="button"
                      class="w-full px-3 py-3 sm:py-2 text-left text-[13px] flex items-center gap-2 hover:bg-[color:var(--color-bg-tertiary)]"
                      data-action="click->event-selector#select"
                      data-value="APPROVE"
                      data-label="Approve">
                <span class="event-icon text-[color:var(--color-status-done)]">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </span>
                Approve
              </button>
            </li>
            <li>
              <button type="button"
                      class="w-full px-3 py-3 sm:py-2 text-left text-[13px] flex items-center gap-2 hover:bg-[color:var(--color-bg-tertiary)]"
                      data-action="click->event-selector#select"
                      data-value="REQUEST_CHANGES"
                      data-label="Request changes">
                <span class="event-icon text-[color:var(--color-status-todo)]">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                  </svg>
                </span>
                Request changes
              </button>
            </li>
          </ul>
        </div>
      </div>
      <button type="submit"
              class="linear-btn linear-btn-primary text-[12px] opacity-50 cursor-not-allowed w-full sm:w-auto justify-center"
              data-comment-checklist-target="submitButton"
              data-action="click->comment-checklist#prepareSubmission"
              disabled>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Submit to GitHub
      </button>
    <% end %>
  </div>
</div>
