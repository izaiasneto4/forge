<% content_for :full_width, true %>
<% content_for :hide_global_header, true %>
<%= turbo_stream_from "review_tasks_board" %>
<div class="min-h-screen flex flex-col" data-controller="review-kanban board-filter archive-confirmation" data-board-filter-storage-key-value="review_tasks_filter">
  <!-- Header -->
  <header class="linear-header">
    <div class="flex items-center gap-3">
      <!-- Logo/Home Link -->
      <%= link_to root_path, class: "flex items-center gap-2 hover:opacity-80 transition-opacity" do %>
        <div class="w-6 h-6 rounded bg-[color:var(--color-accent)] flex items-center justify-center">
          <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
          </svg>
        </div>
        <span class="text-[14px] font-semibold text-[color:var(--color-text-primary)]">Forge</span>
      <% end %>

      <!-- Divider -->
      <span class="text-[color:var(--color-border-default)]">/</span>

      <div class="linear-header-breadcrumb">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
        </svg>
        <span class="text-[color:var(--color-text-tertiary)]">Code Review Tasks</span>
      </div>
    </div>

    <div class="flex items-center gap-2">
      <!-- Settings Link -->
      <%= link_to edit_settings_path, class: "linear-btn linear-btn-ghost p-2", title: "Settings" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
      <% end %>
    </div>
  </header>

  <!-- Search and Filter Bar -->
  <div class="px-6 pt-4 pb-2 flex flex-wrap items-center gap-3 border-b border-[color:var(--color-border-default)] bg-[color:var(--color-bg-primary)]">
    <div class="relative flex-1 min-w-[200px] max-w-[300px]">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-[color:var(--color-text-tertiary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <input type="text"
             placeholder="Search reviews..."
             class="w-full pl-9 pr-4 py-1.5 text-[13px] bg-[color:var(--color-bg-secondary)] border border-[color:var(--color-border-default)] rounded-md focus:outline-none focus:border-[color:var(--color-accent)] focus:ring-1 focus:ring-[color:var(--color-accent)]"
             data-board-filter-target="searchInput"
             data-action="input->board-filter#search">
    </div>

    <div class="flex items-center gap-1">
      <span class="text-[12px] text-[color:var(--color-text-tertiary)] mr-1">State:</span>
      <button type="button"
              class="linear-btn linear-btn-sm linear-btn-primary text-[11px]"
              data-board-filter-target="stateFilter"
              data-state="all"
              data-action="click->board-filter#filterState">
        All
      </button>
      <button type="button"
              class="linear-btn linear-btn-sm linear-btn-ghost text-[11px]"
              data-board-filter-target="stateFilter"
              data-state="queued"
              data-action="click->board-filter#filterState">
        Queued
      </button>
      <button type="button"
              class="linear-btn linear-btn-sm linear-btn-ghost text-[11px]"
              data-board-filter-target="stateFilter"
              data-state="in_review"
              data-action="click->board-filter#filterState">
        In Review
      </button>
      <button type="button"
              class="linear-btn linear-btn-sm linear-btn-ghost text-[11px]"
              data-board-filter-target="stateFilter"
              data-state="reviewed"
              data-action="click->board-filter#filterState">
        Reviewed
      </button>
      <button type="button"
              class="linear-btn linear-btn-sm linear-btn-ghost text-[11px]"
              data-board-filter-target="stateFilter"
              data-state="failed_review"
              data-action="click->board-filter#filterState">
        Failed
      </button>
    </div>

    <button type="button"
            class="linear-btn linear-btn-sm linear-btn-ghost text-[11px] text-[color:var(--color-text-tertiary)]"
            data-action="click->board-filter#clearFilters">
      Clear
    </button>
  </div>

  <div class="flex-1 overflow-x-auto p-6">

    <div class="grid grid-cols-1 md:grid-cols-7 gap-4 overflow-x-auto">
      <!-- Queued Column -->
      <div class="bg-[color:var(--color-bg-secondary)] rounded-lg border border-[color:var(--color-border-default)] min-w-[250px]">
        <div class="p-3 border-b border-[color:var(--color-border-default)] bg-violet-500/10 rounded-t-lg">
          <h2 class="font-medium text-[color:var(--color-text-primary)] flex items-center text-[13px]">
            <span class="w-2.5 h-2.5 bg-violet-500 rounded-full mr-2"></span>
            Queued
            <span id="review_task_count_queued" class="ml-2 linear-badge linear-badge-default text-[10px]">
              <%= @grouped_tasks[:queued].count %>
            </span>
          </h2>
        </div>
        <div id="review_task_column_queued"
             class="p-3 space-y-2 min-h-[200px]"
             data-review-kanban-target="column"
             data-board-filter-target="column"
             data-state="queued">
          <%= render partial: "review_task_card", collection: @grouped_tasks[:queued], as: :task %>
          <p id="review_task_empty_queued" class="text-[color:var(--color-text-tertiary)] text-center py-6 text-[13px] <%= 'hidden' unless @grouped_tasks[:queued].empty? %>">No queued reviews</p>
        </div>
      </div>

      <!-- Pending Review Column -->
      <div class="bg-[color:var(--color-bg-secondary)] rounded-lg border border-[color:var(--color-border-default)] min-w-[250px]">
        <div class="p-3 border-b border-[color:var(--color-border-default)] bg-[color:var(--color-bg-tertiary)] rounded-t-lg">
          <h2 class="font-medium text-[color:var(--color-text-primary)] flex items-center text-[13px]">
            <span class="w-2.5 h-2.5 bg-[color:var(--color-status-todo)] rounded-full mr-2"></span>
            Pending Review
            <span id="review_task_count_pending_review" class="ml-2 linear-badge linear-badge-default text-[10px]">
              <%= @grouped_tasks[:pending_review].count %>
            </span>
          </h2>
        </div>
        <div id="review_task_column_pending_review"
             class="p-3 space-y-2 min-h-[200px]"
             data-review-kanban-target="column"
             data-board-filter-target="column"
             data-state="pending_review">
          <%= render partial: "review_task_card", collection: @grouped_tasks[:pending_review], as: :task %>
          <p id="review_task_empty_pending_review" class="text-[color:var(--color-text-tertiary)] text-center py-6 text-[13px] <%= 'hidden' unless @grouped_tasks[:pending_review].empty? %>">No pending reviews</p>
        </div>
      </div>

      <!-- In Review Column -->
      <div class="bg-[color:var(--color-bg-secondary)] rounded-lg border border-[color:var(--color-border-default)] min-w-[250px]">
        <div class="p-3 border-b border-[color:var(--color-border-default)] bg-[color:var(--color-status-in-progress)]/10 rounded-t-lg">
          <h2 class="font-medium text-[color:var(--color-text-primary)] flex items-center text-[13px]">
            <span class="w-2.5 h-2.5 bg-[color:var(--color-status-in-progress)] rounded-full mr-2 animate-pulse"></span>
            In Review
            <span id="review_task_count_in_review" class="ml-2 linear-badge linear-badge-yellow text-[10px]">
              <%= @grouped_tasks[:in_review].count %>
            </span>
          </h2>
        </div>
        <div id="review_task_column_in_review"
             class="p-3 space-y-2 min-h-[200px]"
             data-review-kanban-target="column"
             data-board-filter-target="column"
             data-state="in_review">
          <%= render partial: "review_task_card", collection: @grouped_tasks[:in_review], as: :task %>
          <p id="review_task_empty_in_review" class="text-[color:var(--color-text-tertiary)] text-center py-6 text-[13px] <%= 'hidden' unless @grouped_tasks[:in_review].empty? %>">No active reviews</p>
        </div>
      </div>

      <!-- Reviewed Column -->
      <div class="bg-[color:var(--color-bg-secondary)] rounded-lg border border-[color:var(--color-border-default)] min-w-[250px]">
        <div class="p-3 border-b border-[color:var(--color-border-default)] bg-[color:var(--color-accent)]/10 rounded-t-lg">
          <h2 class="font-medium text-[color:var(--color-text-primary)] flex items-center text-[13px]">
            <span class="w-2.5 h-2.5 bg-[color:var(--color-accent)] rounded-full mr-2"></span>
            Reviewed
            <span id="review_task_count_reviewed" class="ml-2 linear-badge linear-badge-blue text-[10px]">
              <%= @grouped_tasks[:reviewed].count %>
            </span>
          </h2>
        </div>
        <div id="review_task_column_reviewed"
             class="p-3 space-y-2 min-h-[200px]"
             data-review-kanban-target="column"
             data-board-filter-target="column"
             data-state="reviewed">
          <%= render partial: "review_task_card", collection: @grouped_tasks[:reviewed], as: :task %>
          <p id="review_task_empty_reviewed" class="text-[color:var(--color-text-tertiary)] text-center py-6 text-[13px] <%= 'hidden' unless @grouped_tasks[:reviewed].empty? %>">No reviewed tasks</p>
        </div>
      </div>

      <!-- Waiting Implementation Column -->
      <div class="bg-[color:var(--color-bg-secondary)] rounded-lg border border-[color:var(--color-border-default)] min-w-[250px]">
        <div class="p-3 border-b border-[color:var(--color-border-default)] bg-orange-500/10 rounded-t-lg">
          <h2 class="font-medium text-[color:var(--color-text-primary)] flex items-center text-[13px]">
            <span class="w-2.5 h-2.5 bg-orange-500 rounded-full mr-2"></span>
            Waiting Impl
            <span id="review_task_count_waiting_implementation" class="ml-2 linear-badge linear-badge-purple text-[10px]">
              <%= @grouped_tasks[:waiting_implementation].count %>
            </span>
          </h2>
        </div>
        <div id="review_task_column_waiting_implementation"
             class="p-3 space-y-2 min-h-[200px]"
             data-review-kanban-target="column"
             data-board-filter-target="column"
             data-state="waiting_implementation">
          <%= render partial: "review_task_card", collection: @grouped_tasks[:waiting_implementation], as: :task %>
          <p id="review_task_empty_waiting_implementation" class="text-[color:var(--color-text-tertiary)] text-center py-6 text-[13px] <%= 'hidden' unless @grouped_tasks[:waiting_implementation].empty? %>">No tasks waiting</p>
        </div>
      </div>

      <!-- Done Column -->
      <div class="bg-[color:var(--color-bg-secondary)] rounded-lg border border-[color:var(--color-border-default)] min-w-[250px]">
        <div class="p-3 border-b border-[color:var(--color-border-default)] bg-[color:var(--color-status-done)]/10 rounded-t-lg">
          <h2 class="font-medium text-[color:var(--color-text-primary)] flex items-center text-[13px]">
            <span class="w-2.5 h-2.5 bg-[color:var(--color-status-done)] rounded-full mr-2"></span>
            Done
            <span id="review_task_count_done" class="ml-2 linear-badge linear-badge-green text-[10px]">
              <%= @grouped_tasks[:done].count %>
            </span>
          </h2>
        </div>
        <div id="review_task_column_done"
             class="p-3 space-y-2 min-h-[200px]"
             data-review-kanban-target="column"
             data-board-filter-target="column"
             data-state="done">
          <%= render partial: "review_task_card", collection: @grouped_tasks[:done], as: :task %>
          <p id="review_task_empty_done" class="text-[color:var(--color-text-tertiary)] text-center py-6 text-[13px] <%= 'hidden' unless @grouped_tasks[:done].empty? %>">No completed tasks</p>
        </div>
      </div>

      <!-- Failed Review Column -->
      <div class="bg-[color:var(--color-bg-secondary)] rounded-lg border border-[color:var(--color-border-default)] min-w-[250px]">
        <div class="p-3 border-b border-[color:var(--color-border-default)] bg-red-500/10 rounded-t-lg">
          <h2 class="font-medium text-[color:var(--color-text-primary)] flex items-center text-[13px]">
            <span class="w-2.5 h-2.5 bg-red-500 rounded-full mr-2"></span>
            Failed
            <span id="review_task_count_failed_review" class="ml-2 linear-badge linear-badge-red text-[10px]">
              <%= @grouped_tasks[:failed_review].count %>
            </span>
          </h2>
        </div>
        <div id="review_task_column_failed_review"
             class="p-3 space-y-2 min-h-[200px]"
             data-review-kanban-target="column"
             data-board-filter-target="column"
             data-state="failed_review">
          <%= render partial: "review_task_card", collection: @grouped_tasks[:failed_review], as: :task %>
          <p id="review_task_empty_failed_review" class="text-[color:var(--color-text-tertiary)] text-center py-6 text-[13px] <%= 'hidden' unless @grouped_tasks[:failed_review].empty? %>">No failed reviews</p>
        </div>
      </div>
    </div>
  </div>
</div>

<div id="review-modal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50"
     data-review-kanban-target="modal">
  <div class="relative top-10 mx-auto p-5 border w-11/12 max-w-4xl shadow-lg rounded-md bg-white">
    <div id="review-modal-content" data-review-kanban-target="modalContent">
    </div>
  </div>
</div>

<!-- Backward Move Confirmation Modal -->
<div id="backward-confirm-modal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50"
     data-review-kanban-target="confirmModal">
  <div class="relative top-20 mx-auto border w-full max-w-md shadow-lg rounded-lg bg-white">
    <div id="backward-confirm-modal-content" data-review-kanban-target="confirmModalContent">
    </div>
  </div>
</div>

<!-- Archive Confirmation Modal -->
<%= render partial: "shared/archive_confirmation" %>
