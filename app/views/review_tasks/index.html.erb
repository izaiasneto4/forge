<% content_for :full_width, true %>
<%= turbo_stream_from "review_tasks_board" %>
<div class="min-h-screen bg-gray-100 p-6" data-controller="review-kanban">
  <div class="w-full px-4">
    <div class="flex justify-between items-center mb-6">
      <div class="flex items-center gap-4">
        <h1 class="text-2xl font-bold text-gray-900">Code Review Tasks</h1>
        <%= link_to root_path, class: "flex items-center gap-2 bg-gray-100 hover:bg-gray-200 px-3 py-1.5 rounded-md text-sm font-medium text-gray-700 border border-gray-300" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to PRs
        <% end %>
      </div>
    </div>

    <% if flash[:notice] %>
      <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
        <%= flash[:notice] %>
      </div>
    <% end %>

    <% if flash[:alert] %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <div class="grid grid-cols-1 md:grid-cols-6 gap-4 overflow-x-auto">
      <!-- Pending Review Column -->
      <div class="bg-white rounded-lg shadow min-w-[250px]">
        <div class="p-3 border-b border-gray-200 bg-gray-50 rounded-t-lg">
          <h2 class="font-semibold text-gray-900 flex items-center text-sm">
            <span class="w-2.5 h-2.5 bg-gray-400 rounded-full mr-2"></span>
            Pending Review
            <span id="review_task_count_pending_review" class="ml-2 bg-gray-200 text-gray-700 text-xs px-2 py-0.5 rounded-full">
              <%= @grouped_tasks[:pending_review].count %>
            </span>
          </h2>
        </div>
        <div id="review_task_column_pending_review"
             class="p-3 space-y-2 min-h-[200px]"
             data-review-kanban-target="column"
             data-state="pending_review">
          <%= render partial: "review_task_card", collection: @grouped_tasks[:pending_review], as: :task %>
          <p id="review_task_empty_pending_review" class="text-gray-400 text-center py-6 text-sm <%= 'hidden' unless @grouped_tasks[:pending_review].empty? %>">No pending reviews</p>
        </div>
      </div>

      <!-- In Review Column -->
      <div class="bg-white rounded-lg shadow min-w-[250px]">
        <div class="p-3 border-b border-gray-200 bg-yellow-50 rounded-t-lg">
          <h2 class="font-semibold text-gray-900 flex items-center text-sm">
            <span class="w-2.5 h-2.5 bg-yellow-500 rounded-full mr-2 animate-pulse"></span>
            In Review
            <span id="review_task_count_in_review" class="ml-2 bg-yellow-200 text-yellow-800 text-xs px-2 py-0.5 rounded-full">
              <%= @grouped_tasks[:in_review].count %>
            </span>
          </h2>
        </div>
        <div id="review_task_column_in_review"
             class="p-3 space-y-2 min-h-[200px]"
             data-review-kanban-target="column"
             data-state="in_review">
          <%= render partial: "review_task_card", collection: @grouped_tasks[:in_review], as: :task %>
          <p id="review_task_empty_in_review" class="text-gray-400 text-center py-6 text-sm <%= 'hidden' unless @grouped_tasks[:in_review].empty? %>">No active reviews</p>
        </div>
      </div>

      <!-- Reviewed Column -->
      <div class="bg-white rounded-lg shadow min-w-[250px]">
        <div class="p-3 border-b border-gray-200 bg-blue-50 rounded-t-lg">
          <h2 class="font-semibold text-gray-900 flex items-center text-sm">
            <span class="w-2.5 h-2.5 bg-blue-500 rounded-full mr-2"></span>
            Reviewed
            <span id="review_task_count_reviewed" class="ml-2 bg-blue-200 text-blue-800 text-xs px-2 py-0.5 rounded-full">
              <%= @grouped_tasks[:reviewed].count %>
            </span>
          </h2>
        </div>
        <div id="review_task_column_reviewed"
             class="p-3 space-y-2 min-h-[200px]"
             data-review-kanban-target="column"
             data-state="reviewed">
          <%= render partial: "review_task_card", collection: @grouped_tasks[:reviewed], as: :task %>
          <p id="review_task_empty_reviewed" class="text-gray-400 text-center py-6 text-sm <%= 'hidden' unless @grouped_tasks[:reviewed].empty? %>">No reviewed tasks</p>
        </div>
      </div>

      <!-- Waiting Implementation Column -->
      <div class="bg-white rounded-lg shadow min-w-[250px]">
        <div class="p-3 border-b border-gray-200 bg-orange-50 rounded-t-lg">
          <h2 class="font-semibold text-gray-900 flex items-center text-sm">
            <span class="w-2.5 h-2.5 bg-orange-500 rounded-full mr-2"></span>
            Waiting Impl
            <span id="review_task_count_waiting_implementation" class="ml-2 bg-orange-200 text-orange-800 text-xs px-2 py-0.5 rounded-full">
              <%= @grouped_tasks[:waiting_implementation].count %>
            </span>
          </h2>
        </div>
        <div id="review_task_column_waiting_implementation"
             class="p-3 space-y-2 min-h-[200px]"
             data-review-kanban-target="column"
             data-state="waiting_implementation">
          <%= render partial: "review_task_card", collection: @grouped_tasks[:waiting_implementation], as: :task %>
          <p id="review_task_empty_waiting_implementation" class="text-gray-400 text-center py-6 text-sm <%= 'hidden' unless @grouped_tasks[:waiting_implementation].empty? %>">No tasks waiting</p>
        </div>
      </div>

      <!-- Done Column -->
      <div class="bg-white rounded-lg shadow min-w-[250px]">
        <div class="p-3 border-b border-gray-200 bg-green-50 rounded-t-lg">
          <h2 class="font-semibold text-gray-900 flex items-center text-sm">
            <span class="w-2.5 h-2.5 bg-green-500 rounded-full mr-2"></span>
            Done
            <span id="review_task_count_done" class="ml-2 bg-green-200 text-green-800 text-xs px-2 py-0.5 rounded-full">
              <%= @grouped_tasks[:done].count %>
            </span>
          </h2>
        </div>
        <div id="review_task_column_done"
             class="p-3 space-y-2 min-h-[200px]"
             data-review-kanban-target="column"
             data-state="done">
          <%= render partial: "review_task_card", collection: @grouped_tasks[:done], as: :task %>
          <p id="review_task_empty_done" class="text-gray-400 text-center py-6 text-sm <%= 'hidden' unless @grouped_tasks[:done].empty? %>">No completed tasks</p>
        </div>
      </div>

      <!-- Failed Review Column -->
      <div class="bg-white rounded-lg shadow min-w-[250px]">
        <div class="p-3 border-b border-gray-200 bg-red-50 rounded-t-lg">
          <h2 class="font-semibold text-gray-900 flex items-center text-sm">
            <span class="w-2.5 h-2.5 bg-red-500 rounded-full mr-2"></span>
            Failed
            <span id="review_task_count_failed_review" class="ml-2 bg-red-200 text-red-800 text-xs px-2 py-0.5 rounded-full">
              <%= @grouped_tasks[:failed_review].count %>
            </span>
          </h2>
        </div>
        <div id="review_task_column_failed_review"
             class="p-3 space-y-2 min-h-[200px]"
             data-review-kanban-target="column"
             data-state="failed_review">
          <%= render partial: "review_task_card", collection: @grouped_tasks[:failed_review], as: :task %>
          <p id="review_task_empty_failed_review" class="text-gray-400 text-center py-6 text-sm <%= 'hidden' unless @grouped_tasks[:failed_review].empty? %>">No failed reviews</p>
        </div>
      </div>
    </div>
  </div>
</div>

<div id="review-modal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50"
     data-review-kanban-target="modal">
  <div class="relative top-10 mx-auto p-5 border w-11/12 max-w-4xl shadow-lg rounded-md bg-white">
    <div id="review-modal-content" data-review-kanban-target="modalContent">
    </div>
  </div>
</div>

<!-- Backward Move Confirmation Modal -->
<div id="backward-confirm-modal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50"
     data-review-kanban-target="confirmModal">
  <div class="relative top-20 mx-auto border w-full max-w-md shadow-lg rounded-lg bg-white">
    <div id="backward-confirm-modal-content" data-review-kanban-target="confirmModalContent">
    </div>
  </div>
</div>
