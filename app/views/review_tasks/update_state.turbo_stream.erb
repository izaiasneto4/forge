<%# Remove the card from its current location %>
<%= turbo_stream.remove "review_task_card_#{@review_task.id}" %>

<%# Append the card to the correct column based on new state %>
<%= turbo_stream.append "review_task_column_#{@review_task.state}" do %>
  <%= render partial: "review_tasks/review_task_card", locals: { task: @review_task } %>
<% end %>

<%# Update column counts %>
<% grouped_tasks = {
  queued: ReviewTask.queued.count,
  pending_review: ReviewTask.pending_review.count,
  in_review: ReviewTask.in_review.count,
  reviewed: ReviewTask.reviewed.count,
  waiting_implementation: ReviewTask.waiting_implementation.count,
  done: ReviewTask.done.count,
  failed_review: ReviewTask.failed_review.count
} %>

<%= turbo_stream.update "review_task_count_queued" do %>
  <%= grouped_tasks[:queued] %>
<% end %>

<%= turbo_stream.update "review_task_count_pending_review" do %>
  <%= grouped_tasks[:pending_review] %>
<% end %>

<%= turbo_stream.update "review_task_count_in_review" do %>
  <%= grouped_tasks[:in_review] %>
<% end %>

<%= turbo_stream.update "review_task_count_reviewed" do %>
  <%= grouped_tasks[:reviewed] %>
<% end %>

<%= turbo_stream.update "review_task_count_waiting_implementation" do %>
  <%= grouped_tasks[:waiting_implementation] %>
<% end %>

<%= turbo_stream.update "review_task_count_done" do %>
  <%= grouped_tasks[:done] %>
<% end %>

<%= turbo_stream.update "review_task_count_failed_review" do %>
  <%= grouped_tasks[:failed_review] %>
<% end %>

<%# Update empty state visibility %>
<% ReviewTask::STATES.each do |state| %>
  <% count = grouped_tasks[state.to_sym] %>
  <%= turbo_stream.replace "review_task_empty_#{state}" do %>
    <%= render partial: "review_tasks/empty_state", locals: { state: state, hidden: count > 0 } %>
  <% end %>
<% end %>
