<div id="review_task_card_<%= task.id %>"
     class="kanban-card bg-gray-50 border border-gray-200 rounded-lg p-3 hover:shadow-md transition-shadow"
     data-review-kanban-target="card"
     data-task-id="<%= task.id %>"
     data-current-state="<%= task.state %>"
     draggable="true"
     tabindex="0"
     role="button"
     aria-roledescription="draggable card"
     aria-label="<%= task.pull_request.title %>, currently in <%= task.state.humanize %>"
     aria-describedby="card_instructions_<%= task.id %>"
     data-action="dragstart->review-kanban#dragStart dragend->review-kanban#dragEnd click->review-kanban#showReview keydown->review-kanban#handleKeydown">
  <span id="card_instructions_<%= task.id %>" class="sr-only">
    Press Space or Enter to pick up. Use arrow keys to move between columns. Press Space or Enter to drop, or Escape to cancel.
  </span>
  <% pr = task.pull_request %>

  <div class="flex items-start justify-between mb-2">
    <div class="flex items-center space-x-2">
      <!-- Drag handle -->
      <div class="kanban-drag-handle" aria-hidden="true" title="Drag to move">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16" />
        </svg>
      </div>
      <% if pr.author_avatar.present? %>
        <img src="<%= pr.author_avatar %>" alt="<%= pr.author %>" class="w-5 h-5 rounded-full">
      <% else %>
        <div class="w-5 h-5 rounded-full bg-gray-300 flex items-center justify-center text-xs text-gray-600">
          <%= pr.author&.first&.upcase %>
        </div>
      <% end %>
      <span class="text-xs text-gray-600"><%= pr.author %></span>
    </div>
    <span class="text-xs text-gray-400">#<%= pr.number %></span>
  </div>

  <div class="flex items-start justify-between gap-2 mb-1">
    <h3 class="font-medium text-gray-900 text-sm line-clamp-2 flex-1">
      <%= link_to pr.title, review_task_path(task),
          class: "hover:text-blue-600 hover:underline",
          data: { action: "click->review-kanban#navigateToReview" },
          title: "View review details" %>
    </h3>
    <%= link_to pr.url, target: "_blank", rel: "noopener noreferrer",
        class: "flex-shrink-0 text-gray-400 hover:text-gray-600",
        data: { action: "click->review-kanban#openGithub" },
        title: "Open on GitHub" do %>
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 16 16">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
      </svg>
    <% end %>
  </div>

  <div class="flex items-center justify-between text-xs text-gray-400 mt-2">
    <div class="flex items-center gap-1.5">
      <span class="bg-gray-200 px-1.5 py-0.5 rounded truncate max-w-[80px]" title="<%= pr.repo_full_name %>">
        <%= pr.repo_name %>
      </span>
      <% if task.swarm_review? %>
        <span class="bg-purple-100 text-purple-700 px-1.5 py-0.5 rounded text-[10px] font-medium" title="Multi-agent swarm review">
          Swarm
        </span>
      <% end %>
      <% if task.retry_count > 0 && !task.failed_review? %>
        <span class="bg-yellow-100 text-yellow-700 px-1.5 py-0.5 rounded text-[10px] font-medium" title="Retry <%= task.retry_count %>/<%= ReviewTask::MAX_RETRY_ATTEMPTS %>">
          Retry <%= task.retry_count %>
        </span>
      <% end %>
      <% if task.has_review_history? %>
        <span class="bg-blue-100 text-blue-700 px-1.5 py-0.5 rounded text-[10px] font-medium" title="<%= task.review_iterations.count %> previous review(s)">
          #<%= task.current_iteration_number + 1 %>
        </span>
      <% end %>
    </div>
    <% if task.pending_review? || task.in_review? %>
      <span class="text-yellow-600 animate-pulse">In Review...</span>
    <% elsif task.failed_review? %>
      <span class="text-red-600" title="<%= task.failure_reason %>">Failed</span>
    <% elsif task.completed_at %>
      <span title="<%= task.completed_at.strftime('%Y-%m-%d %H:%M') %>">
        <%= time_ago_in_words(task.completed_at) %> ago
      </span>
    <% end %>
  </div>

  <% if task.reviewed? || task.waiting_implementation? || task.done? %>
    <div class="mt-2 pt-2 border-t border-gray-200">
      <button type="button"
              class="text-xs text-blue-600 hover:text-blue-800 font-medium"
              data-action="click->review-kanban#showReview"
              data-task-id="<%= task.id %>">
        View Review Output
      </button>
    </div>
  <% end %>

  <% if task.failed_review? %>
    <div class="mt-2 pt-2 border-t border-red-200 bg-red-50 -mx-3 -mb-3 px-3 py-2 rounded-b-lg">
      <div class="text-xs text-red-700 mb-1 line-clamp-2" title="<%= task.failure_reason %>">
        <%= truncate(task.failure_reason, length: 100) %>
      </div>
      <div class="flex items-center justify-between">
        <span class="text-[10px] text-red-500">
          <%= task.retry_count %>/<%= ReviewTask::MAX_RETRY_ATTEMPTS %> retries
        </span>
        <% if task.can_retry? %>
          <%= button_to retry_review_task_path(task),
              method: :post,
              class: "retry-btn flex items-center gap-1 text-xs text-red-600 hover:text-red-800 font-medium disabled:opacity-50 disabled:cursor-not-allowed",
              data: {
                turbo_confirm: "Retry this review?",
                disable_with: "Retrying..."
              } do %>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
            Retry
          <% end %>
        <% else %>
          <span class="text-[10px] text-red-400 italic">Max retries reached</span>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
