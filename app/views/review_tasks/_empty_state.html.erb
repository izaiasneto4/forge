<%# Empty state message for review task columns %>
<% messages = {
  "pending_review" => "No pending reviews",
  "in_review" => "No active reviews",
  "reviewed" => "No reviewed tasks",
  "waiting_implementation" => "No tasks waiting",
  "done" => "No completed tasks",
  "failed_review" => "No failed reviews"
} %>
<p id="review_task_empty_<%= state %>"
   class="text-gray-400 text-center py-6 text-sm <%= 'hidden' if hidden %>">
  <%= messages[state] || "No tasks" %>
</p>
