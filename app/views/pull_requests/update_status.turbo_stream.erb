<%# Remove card from current column %>
<%= turbo_stream.remove "pull_request_card_#{@pull_request.id}" %>

<%# Append card to correct column based on new status %>
<% target_column = @pull_request.review_status %>
<%= turbo_stream.append "pull_request_column_#{target_column}" do %>
  <%= render partial: "pull_requests/pull_request_card", locals: { pr: @pull_request } %>
<% end %>

<%# Update column counts %>
<% counts = {
  pending_review: PullRequest.pending_review.count,
  in_review: PullRequest.in_review.count,
  reviewed_by_me: PullRequest.reviewed_by_me.count,
  waiting_implementation: PullRequest.waiting_implementation.count,
  reviewed_by_others: PullRequest.reviewed_by_others.count,
  review_failed: PullRequest.review_failed.count
} %>

<%= turbo_stream.update "pr_count_pending_review" do %>
  <%= counts[:pending_review] %>
<% end %>

<%= turbo_stream.update "pr_count_in_review" do %>
  <%= counts[:in_review] %>
<% end %>

<%= turbo_stream.update "pr_count_reviewed_by_me" do %>
  <%= counts[:reviewed_by_me] %>
<% end %>

<%= turbo_stream.update "pr_count_waiting_implementation" do %>
  <%= counts[:waiting_implementation] %>
<% end %>

<%= turbo_stream.update "pr_count_reviewed_by_others" do %>
  <%= counts[:reviewed_by_others] %>
<% end %>

<%= turbo_stream.update "pr_count_review_failed" do %>
  <%= counts[:review_failed] %>
<% end %>

<%# Update total PR count %>
<%= turbo_stream.update "pr-count" do %>
  <%= counts.values.sum %> PRs
<% end %>
