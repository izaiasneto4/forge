<%# Re-render the PR card in its correct column based on review_status %>
<%= turbo_stream.remove "pull_request_card_#{@pull_request.id}" %>

<%= turbo_stream.append "pr_column_#{@pull_request.review_status}" do %>
  <%= render partial: "pull_requests/pull_request_card", locals: { pr: @pull_request } %>
<% end %>

<%# Update column counts %>
<% presenter = PullRequestIndexPresenter.new %>
<% columns = presenter.columns %>

<%= turbo_stream.update "pr-count", "#{presenter.total_count} pull requests" %>
