<div data-bulk-actions-target="modal"
     data-action="click->bulk-actions#hideDeleteModal"
     class="hidden fixed inset-0 linear-overlay-soft z-50 flex items-center justify-center backdrop-blur-sm">
  <div class="bg-[color:var(--color-bg-secondary)] rounded-lg shadow-xl border border-[color:var(--color-border-default)] max-w-md mx-4"
       data-action="click->bulk-actions#stopPropagation">
    <div class="linear-modal-accent linear-accent-danger" aria-hidden="true"></div>

    <div class="linear-modal-header">
      <div>
        <h2 class="linear-modal-title linear-text-danger">Delete Pull Requests</h2>
        <p class="linear-modal-subtitle mt-2">
          You are about to delete <span data-bulk-actions-target="count" class="font-semibold">0</span> pull request(s).
        </p>
      </div>
      <button type="button"
              data-action="click->bulk-actions#hideDeleteModal"
              class="linear-modal-close">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div class="p-6">
      <div class="linear-surface-warning rounded-lg p-4 mb-4">
        <div class="flex gap-3">
          <svg class="w-5 h-5 linear-text-warning flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
          <div class="text-[13px] linear-text-warning">
            <p class="font-medium mb-1">This action will:</p>
            <ul class="list-disc list-inside space-y-1 linear-text-warning">
              <li>Soft-delete the selected pull requests</li>
              <li>They will be restored on the next sync if still open on GitHub</li>
              <li>Restored PRs will appear in "Needs Review" status</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="flex gap-2 justify-end">
        <button type="button"
                data-action="click->bulk-actions#hideDeleteModal"
                class="linear-btn linear-btn-secondary text-[13px] py-2 px-4">
          Cancel
        </button>
        <button type="button"
                data-action="click->bulk-actions#confirmDelete"
                class="linear-btn linear-btn-danger text-[13px] py-2 px-4">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
          Delete Pull Requests
        </button>
      </div>
    </div>
  </div>
</div>
