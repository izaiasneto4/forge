<div data-bulk-actions-target="toolbar"
     class="hidden linear-filter-bar flex items-center justify-between linear-surface-info border-b-2 linear-border-info">
  <div class="flex items-center gap-3">
    <svg class="w-4 h-4 linear-text-info" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
    </svg>
    <span class="text-[13px] font-medium linear-text-info">
      <span data-bulk-actions-target="count">0</span> selected
    </span>
  </div>

  <div class="flex items-center gap-2">
    <button type="button"
            data-action="click->bulk-actions#showDeleteModal"
            data-bulk-actions-target="deleteButton"
            class="linear-btn linear-btn-secondary text-[13px] py-1.5 linear-text-danger hover:bg-[color:var(--color-surface-danger-bg)]">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
      </svg>
      Delete
    </button>
  </div>
</div>
