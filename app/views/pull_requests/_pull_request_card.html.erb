<div id="pull_request_card_<%= pr.id %>"
     class="linear-card"
     data-kanban-target="card"
     data-board-filter-target="card"
     data-pr-id="<%= pr.id %>"
     data-current-state="<%= pr.review_status %>"
     draggable="true"
     data-action="dragstart->kanban#dragStart dragend->kanban#dragEnd">
  <% task = pr.review_task %>
  <% show_progress_action = task.present? && (task.in_progress_or_retrying? || task.queued?) %>
  <% show_review_output_action = task.present? && (task.failed_review? || task.reviewed? || task.waiting_implementation? || task.done?) %>

  <!-- Card Header: ID and Status -->
  <div class="flex items-center justify-between mb-2">
    <div class="flex items-center gap-2">
      <% if local_assigns[:show_checkbox] %>
        <input type="checkbox"
               value="<%= pr.id %>"
               data-bulk-actions-target="checkbox"
               data-action="change->bulk-actions#updateSelection"
               class="rounded border-gray-300 text-blue-600 focus:ring-blue-500 cursor-pointer">
      <% end %>
      <span class="linear-card-id">#<%= pr.number %></span>
    </div>
    <div class="flex items-center gap-1">
      <button type="button"
              data-action="click->archive-confirmation#open"
              data-archive-url="<%= archive_pull_request_path(pr) %>"
              data-archive-item-type="pull request"
              data-archive-item-type-label="pull request"
              class="p-1 rounded cursor-pointer hover:bg-[color:var(--color-bg-tertiary)] text-[color:var(--color-text-secondary)] hover:text-[color:var(--color-text)] transition-colors"
              title="Archive">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
        </svg>
      </button>
      <% if task.present? %>
        <div class="flex items-center gap-1">
        <% if task.swarm_review? %>
          <span class="linear-badge linear-badge-purple text-[10px]" title="Swarm Review">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </span>
        <% end %>
        <% if show_progress_action %>
          <span class="linear-badge linear-badge-yellow text-[10px] animate-pulse">
            <svg class="w-3 h-3 animate-spin mr-1" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            <% if task.queued? %>
              Queued
            <% elsif task.retry_count > 0 %>
              Retry <%= task.retry_count %>
            <% else %>
              In Review
            <% end %>
          </span>
        <% elsif task.pending_review? %>
          <span class="linear-badge linear-badge-default text-[10px]">Ready</span>
        <% elsif task.failed_review? %>
          <span class="linear-badge bg-red-100 text-red-700 text-[10px]" title="<%= task.failure_reason %>">
            <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            Failed
          </span>
        <% else %>
          <span class="linear-badge linear-badge-green text-[10px]">Reviewed</span>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

  <!-- Card Title -->
  <a href="<%= pr.url %>"
     target="_blank"
     class="block"
     data-action="click->kanban#markAsReviewed"
     data-pr-id="<%= pr.id %>">
    <h3 class="linear-card-title line-clamp-2">
      <%= pr.title %>
    </h3>
  </a>

  <!-- Card Meta -->
  <div class="linear-card-meta mt-3">
    <!-- Repo Label -->
    <span class="linear-card-label" title="<%= pr.repo_full_name %>">
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
      </svg>
      <%= pr.repo_name %>
    </span>

    <div class="flex-1"></div>

    <!-- Author -->
    <div class="flex items-center gap-1.5">
      <% if pr.author_avatar.present? %>
        <img src="<%= pr.author_avatar %>"
             alt="<%= pr.author %>"
             class="linear-card-avatar"
             title="<%= pr.author %>">
      <% else %>
        <div class="linear-card-avatar bg-[color:var(--color-bg-tertiary)] flex items-center justify-center text-[9px] font-medium text-[color:var(--color-text-secondary)]" title="<%= pr.author %>">
          <%= pr.author&.first&.upcase %>
        </div>
      <% end %>
      <span class="text-[11px] text-[color:var(--color-text-secondary)] truncate max-w-[80px]" title="<%= pr.author %>">
        <%= pr.author %>
      </span>
    </div>
  </div>

  <!-- Action Button -->
  <div class="mt-3 pt-3 border-t border-[color:var(--color-border-subtle)]">
    <% if show_progress_action || show_review_output_action %>
      <%= link_to review_task_path(task),
          class: "linear-btn linear-btn-ghost w-full text-[12px] py-1.5 #{show_progress_action ? 'text-[color:var(--color-status-todo)]' : 'text-[color:var(--color-accent)]'}" do %>
        <% if show_progress_action %>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
          View Progress
        <% else %>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          View Review
        <% end %>
      <% end %>
    <% else %>
      <button type="button"
              data-action="click->review-modal#open"
              data-pr-id="<%= pr.id %>"
              data-pr-title="<%= pr.title %>"
              data-pr-number="<%= pr.number %>"
              class="linear-btn linear-btn-ghost w-full text-[12px] py-1.5 text-[color:var(--color-status-review)]">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
        </svg>
        Review
      </button>
    <% end %>
  </div>
</div>
