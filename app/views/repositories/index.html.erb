<% content_for :full_width, true %>
<div class="min-h-screen flex flex-col">
  <!-- Page Header Bar -->
  <div class="linear-filter-bar flex flex-col sm:flex-row sm:items-center justify-between gap-2 border-b border-[color:var(--color-border-default)]">
    <div class="flex items-center gap-3">
      <h1 class="text-[14px] font-medium text-[color:var(--color-text-primary)]">Select Repository</h1>
    </div>
    <div class="flex gap-2 w-full sm:w-auto">
      <%= link_to "Back to Dashboard", pull_requests_path, class: "linear-btn linear-btn-secondary text-[13px] w-full sm:w-auto" %>
    </div>
  </div>

  <div class="flex-1 p-4 md:p-6">
    <div class="max-w-4xl mx-auto">

      <% if @repos_folder.blank? %>
        <div class="bg-[color:var(--color-bg-secondary)] border border-[color:var(--color-status-todo)] rounded-lg p-4 mb-4">
          <p class="font-medium text-[color:var(--color-text-primary)] text-[14px]">No repos folder configured</p>
          <p class="text-[13px] text-[color:var(--color-text-secondary)] mt-1">
            <%= link_to "Configure your repos folder", edit_settings_path, class: "text-[color:var(--color-accent)] hover:underline" %>
            to see your repositories.
          </p>
        </div>
      <% else %>
        <div class="bg-[color:var(--color-bg-secondary)] border border-[color:var(--color-border-default)] rounded-lg px-4 py-3 mb-4">
          <p class="text-[13px] text-[color:var(--color-text-secondary)]">
            Scanning folder: <code class="bg-[color:var(--color-bg-tertiary)] px-1.5 py-0.5 rounded text-[12px] break-all"><%= @repos_folder %></code>
          </p>
        </div>

        <% if @repositories.empty? %>
          <div class="linear-empty py-16">
            <svg class="w-8 h-8 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
            </svg>
            <span class="text-[14px]">No git repositories found in this folder</span>
          </div>
        <% else %>
          <div class="bg-[color:var(--color-bg-secondary)] rounded-lg border border-[color:var(--color-border-default)] overflow-hidden">
            <ul class="divide-y divide-[color:var(--color-border-default)]">
              <% @repositories.each do |repo| %>
                <li class="hover:bg-[color:var(--color-bg-tertiary)] transition-colors">
                  <%= link_to switch_repositories_path(repo_path: repo[:path]),
                      method: :post,
                      data: { turbo_method: :post },
                      class: "block p-4 #{@current_repo == repo[:path] ? 'bg-[color:var(--color-accent)]/5 border-l-2 border-[color:var(--color-accent)]' : ''}" do %>
                    <div class="flex items-center justify-between gap-3">
                      <div class="min-w-0 flex-1">
                        <h3 class="font-medium text-[14px] text-[color:var(--color-text-primary)] flex items-center">
                          <% if @current_repo == repo[:path] %>
                            <span class="w-2 h-2 bg-[color:var(--color-accent)] rounded-full mr-2"></span>
                          <% end %>
                          <%= repo[:name] %>
                        </h3>
                        <p class="text-[12px] text-[color:var(--color-text-tertiary)] mt-1">
                          <code class="break-all"><%= repo[:path] %></code>
                        </p>
                        <% if repo[:branch].present? %>
                          <p class="text-[11px] text-[color:var(--color-text-tertiary)] mt-1">
                            Branch: <span class="font-mono"><%= repo[:branch] %></span>
                          </p>
                        <% end %>
                      </div>
                      <div class="text-[color:var(--color-text-tertiary)]">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                      </div>
                    </div>
                  <% end %>
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
