<%# Partial for rendering a single review comment %>
<%# Locals: comment - a ReviewComment instance %>
<div id="<%= dom_id(comment) %>"
     class="bg-[color:var(--color-bg-secondary)] rounded-lg border border-[color:var(--color-border-default)] overflow-hidden <%= 'opacity-60' if comment.dismissed? %>">
  <div class="p-4 border-l-4 <%= severity_border_class(comment.severity) %>">
    <div class="flex items-start gap-3">
      <span class="text-xl flex-shrink-0"><%= severity_emoji(comment.severity) %></span>
      <div class="flex-1 min-w-0">
        <div class="flex items-center justify-between gap-2 mb-3">
          <div class="flex items-center gap-2">
            <% if comment.title.present? %>
              <span class="font-medium text-[color:var(--color-text-primary)] text-[13px]"><%= comment.title %></span>
            <% end %>
            <code class="text-[12px] font-mono bg-[color:var(--color-bg-tertiary)] px-2 py-1 rounded text-[color:var(--color-text-primary)]">
              <%= comment.location %>
            </code>
            <span class="linear-badge <%= severity_badge_class(comment.severity) %> text-[10px]">
              <%= comment.severity.capitalize %>
            </span>
          </div>

          <div class="flex items-center gap-2">
            <span class="linear-badge <%= status_badge_class(comment.status) %> text-[10px]">
              <%= comment.status.capitalize %>
            </span>
            <%= button_to toggle_review_comment_path(comment),
                          method: :patch,
                          class: "linear-btn linear-btn-ghost text-[11px] py-1 px-2",
                          data: { turbo_stream: true } do %>
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
              </svg>
              Toggle Status
            <% end %>
          </div>
        </div>

        <% if comment.body.present? %>
          <div class="prose prose-sm max-w-none text-[color:var(--color-text-secondary)] mb-4 text-[13px] leading-relaxed">
            <%= render_markdown(comment.body) %>
          </div>
        <% end %>

        <% if comment.resolution_note.present? %>
          <div class="mt-3 text-[12px] text-[color:var(--color-text-tertiary)] italic">
            <strong>Note:</strong> <%= comment.resolution_note %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
