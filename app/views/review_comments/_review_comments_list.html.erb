<%# Partial for rendering the list of review comments %>
<%# Locals: review_task - a ReviewTask instance %>
<% comments = review_task.review_comments.by_severity %>

<% if comments.any? %>
  <div class="space-y-3">
    <% comments.each do |comment| %>
      <%= render partial: "review_comments/review_comment", locals: { comment: comment } %>
    <% end %>
  </div>
<% else %>
  <div class="linear-empty py-8">
    <svg class="w-6 h-6 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
    </svg>
    <span class="text-[13px]">No review comments yet</span>
  </div>
<% end %>
