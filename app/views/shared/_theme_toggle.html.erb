<button type="button"
        class="linear-btn linear-btn-ghost linear-btn-sm theme-toggle"
        data-action="click->theme#toggle"
        data-theme-target="toggle"
        aria-pressed="false"
        aria-label="Switch to dark mode"
        title="Switch to dark mode">
  <span data-theme-target="lightIcon" class="flex items-center">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m8-9h1M3 12H2m15.364 6.364l.707.707M5.636 5.636l-.707-.707m12.728 0l-.707.707M5.636 18.364l-.707.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
    </svg>
  </span>
  <span data-theme-target="darkIcon" class="hidden items-center">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 118.646 3.646 7 7 0 1020.354 15.354z" />
    </svg>
  </span>
  <span data-theme-target="label" class="hidden sm:inline text-[12px]">Light</span>
</button>
