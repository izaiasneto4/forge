<div id="archive_confirmation_modal"
     data-archive-confirmation-target="modal"
     class="hidden fixed inset-0 bg-black/30 z-50 flex items-center justify-center backdrop-blur-sm">
  <div class="bg-[color:var(--color-bg-secondary)] rounded-lg shadow-xl border border-[color:var(--color-border-default)] max-w-md mx-4"
       data-action="click->archive-confirmation#stopPropagation">
    <div class="linear-modal-accent bg-gray-500" aria-hidden="true"></div>

    <div class="linear-modal-header">
      <div>
        <h2 class="linear-modal-title">Archive <span data-archive-confirmation-target="itemType"></span></h2>
        <p class="linear-modal-subtitle mt-2">
          Are you sure you want to archive this <span data-archive-confirmation-target="itemTypeLabel"></span>?
        </p>
      </div>
      <button type="button"
              data-action="click->archive-confirmation#close"
              class="linear-modal-close">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div class="p-6">
      <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 mb-4">
        <div class="flex gap-3">
          <svg class="w-5 h-5 text-gray-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
          </svg>
          <div class="text-[13px] text-gray-700">
            <p class="font-medium mb-1">Archived items will:</p>
            <ul class="list-disc list-inside space-y-1 text-gray-600">
              <li>Be hidden from the kanban board</li>
              <li>Be restorable at any time from settings</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="flex gap-2 justify-end">
        <button type="button"
                data-action="click->archive-confirmation#close"
                class="linear-btn linear-btn-secondary text-[13px] py-2 px-4">
          Cancel
        </button>
        <form data-archive-confirmation-target="form" method="POST">
          <input type="hidden" name="_method" value="PATCH" data-archive-confirmation-target="methodInput">
          <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
          <button type="submit"
                  class="linear-btn linear-btn-primary bg-gray-600 hover:bg-gray-700 text-white text-[13px] py-2 px-4">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
            </svg>
            Archive
          </button>
        </form>
      </div>
    </div>
  </div>
</div>
