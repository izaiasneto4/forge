<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Forge" %></title>
    <%# Responsive viewport with support for notched devices (no user-scalable=no to allow pinch-to-zoom) %>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="application-name" content="Forge">
    <meta name="mobile-web-app-capable" content="yes">
    <% saved_theme_preference = Setting.theme_preference %>
    <meta name="forge-theme-preference" content="<%= saved_theme_preference.to_s %>">
    <meta name="theme-color" content="<%= saved_theme_preference == "dark" ? "#111827" : "#ffffff" %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <script>
      (() => {
        const preferenceMeta = document.querySelector('meta[name="forge-theme-preference"]')
        const savedPreference = preferenceMeta?.content
        const prefersDark = window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches
        const theme = savedPreference === "dark" || savedPreference === "light" ? savedPreference : (prefersDark ? "dark" : "light")

        document.documentElement.dataset.theme = theme
        document.documentElement.style.colorScheme = theme

        const themeColorMeta = document.querySelector('meta[name="theme-color"]')
        if (themeColorMeta) {
          themeColorMeta.setAttribute("content", theme === "dark" ? "#111827" : "#ffffff")
        }
      })()
    </script>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Inter font - Modern, smooth typography %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "rouge", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="safe-area-inset"
        data-controller="theme notifications"
        data-theme-update-url-value="<%= theme_settings_path %>">
    <%# Global unified header %>
    <% unless content_for?(:hide_global_header) %>
      <%= render partial: "shared/header" %>
    <% end %>

    <%# Global flash messages - fixed at top of viewport with safe area support %>
    <% if flash[:notice].present? || flash[:alert].present? %>
      <div class="fixed top-16 left-1/2 transform -translate-x-1/2 z-50 w-full max-w-lg px-4 safe-area-inset">
        <%= render partial: "shared/flash", locals: { notice: flash[:notice], alert: flash[:alert] } %>
      </div>
    <% end %>

    <% if content_for?(:full_width) %>
      <%= yield %>
    <% else %>
      <%# Responsive main content: smaller padding on mobile, centered container %>
      <main class="container mx-auto mt-20 md:mt-28 px-4 md:px-5 flex max-content-width">
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>
