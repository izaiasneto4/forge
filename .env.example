# Development defaults
FORGE_API_URL=http://127.0.0.1:3000

# Optional runtime tuning
# RAILS_MAX_THREADS=5
# JOB_CONCURRENCY=1
# WEB_CONCURRENCY=1
# RAILS_LOG_LEVEL=info

# Optional model overrides used by some review clients
# ANTHROPIC_MODEL=claude
# CLAUDE_MODEL=claude

# Production-only example
# RAILS_MASTER_KEY=replace_me
